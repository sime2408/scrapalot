# Scrapalot Backend Environment Variables
# Copy this file to .env and configure for your environment

# ============================================================================
# Server Configuration
# ============================================================================
SERVER_PORT=8091
SPRING_PROFILES_ACTIVE=dev  # dev, prod

# ============================================================================
# Database Configuration (PostgreSQL)
# ============================================================================
# Spring Boot Backend Database (pgvector Docker container)
POSTGRES_BACKEND_HOST=localhost
POSTGRES_BACKEND_PORT=5432
POSTGRES_BACKEND_DB=scrapalot_backend
POSTGRES_BACKEND_USER=scrapalot
POSTGRES_BACKEND_PASSWORD=scrapalot123

# Database Pool Configuration
DB_POOL_SIZE=10
DB_POOL_MIN_IDLE=2
DB_CONNECTION_TIMEOUT=30000
DB_IDLE_TIMEOUT=600000
DB_MAX_LIFETIME=1800000

# Hibernate Configuration
HIBERNATE_DDL_AUTO=update  # update, validate, create, create-drop
HIBERNATE_SHOW_SQL=false
HIBERNATE_FORMAT_SQL=false
HIBERNATE_USE_SQL_COMMENTS=false
HIBERNATE_BATCH_SIZE=20

# ============================================================================
# Security Configuration
# ============================================================================
# JWT Configuration
JWT_SECRET=8f4b6c2a1e9d7f3b5a0c8e6d4a2b0f1e  # CHANGE IN PRODUCTION (min 256 bits)
JWT_EXPIRATION_MS=1800000          # 30 minutes in milliseconds
JWT_REFRESH_EXPIRATION_MS=604800000  # 7 days in milliseconds
JWT_ISSUER=scrapalot-backend

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,PATCH,OPTIONS
CORS_ALLOWED_HEADERS=*
CORS_ALLOW_CREDENTIALS=true
CORS_MAX_AGE=3600

# ============================================================================
# OAuth Configuration (Google)
# ============================================================================
GOOGLE_OAUTH_ENABLED=true
GOOGLE_OAUTH_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8091/api/v1/auth/google/callback
FRONTEND_URL=http://localhost:3000

# ============================================================================
# Redis Configuration (Event-Driven Communication with Python)
# ============================================================================
REDIS_ENABLED=true
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=0
REDIS_TIMEOUT=2000
REDIS_POOL_MAX_ACTIVE=8
REDIS_POOL_MAX_IDLE=8
REDIS_POOL_MIN_IDLE=0

# ============================================================================
# gRPC Server Configuration (Communication with Python FastAPI and API Gateway)
# ============================================================================
GRPC_SERVER_PORT=9090
GRPC_SERVER_ADDRESS=0.0.0.0
GRPC_REFLECTION_ENABLED=true

# ============================================================================
# File Upload Configuration
# ============================================================================
UPLOAD_PATH=data/upload
UPLOAD_MAX_SIZE_MB=10
UPLOAD_ALLOWED_EXTENSIONS=.pdf,.txt,.md,.docx,.html,.csv,.json
MAX_FILE_SIZE=10MB
MAX_REQUEST_SIZE=10MB
FILE_SIZE_THRESHOLD=2MB

# ============================================================================
# Logging Configuration
# ============================================================================
LOG_LEVEL_ROOT=INFO
LOG_LEVEL_APP=INFO
LOG_LEVEL_SPRING_WEB=INFO
LOG_LEVEL_SPRING_SECURITY=INFO
LOG_LEVEL_HIBERNATE_SQL=WARN
LOG_LEVEL_HIBERNATE_BINDER=WARN

# ============================================================================
# Actuator Configuration
# ============================================================================
ACTUATOR_ENDPOINTS=health,info,metrics,prometheus
ACTUATOR_HEALTH_DETAILS=when-authorized
PROMETHEUS_ENABLED=true

# ============================================================================
# WebSocket Configuration
# ============================================================================
WEBSOCKET_ENABLED=true
WEBSOCKET_BROKER_HOST=localhost
WEBSOCKET_BROKER_PORT=61613
WEBSOCKET_MESSAGE_SIZE=65536
WEBSOCKET_SEND_BUFFER=524288
WEBSOCKET_SEND_TIME=20000

# ============================================================================
# API Documentation (Swagger/OpenAPI)
# ============================================================================
SPRINGDOC_ENABLED=true
SWAGGER_UI_ENABLED=true

# ============================================================================
# Jackson Configuration
# ============================================================================
JACKSON_INDENT_OUTPUT=false  # true for development, false for production

# ============================================================================
# Liquibase Configuration (Database Migration Management)
# ============================================================================
LIQUIBASE_ENABLED=true
LIQUIBASE_DEFAULT_SCHEMA=scrapalot
LIQUIBASE_SCHEMA=public
LIQUIBASE_DROP_FIRST=false
LIQUIBASE_CONTEXTS=dev,prod
LIQUIBASE_LABELS=

# ============================================================================
# Production-Only Variables (Cloud Deployment)
# ============================================================================
# For GitHub Actions deployment, add these as GitHub Secrets:
# - POSTGRES_BACKEND_HOST, POSTGRES_BACKEND_PORT, POSTGRES_BACKEND_DB
# - POSTGRES_BACKEND_USER, POSTGRES_BACKEND_PASSWORD
# - JWT_SECRET (generate with: openssl rand -base64 32)
# - REDIS_PASSWORD
# - GOOGLE_OAUTH_CLIENT_ID, GOOGLE_OAUTH_CLIENT_SECRET
# - GOOGLE_OAUTH_REDIRECT_URI, FRONTEND_URL

# Production Database (pgvector Docker container)
# POSTGRES_BACKEND_HOST=pgvector
# POSTGRES_BACKEND_PORT=5432
# POSTGRES_BACKEND_PASSWORD=your-strong-password

# Production Security
# JWT_SECRET=your-production-secret-min-256-bits

# Production CORS
# CORS_ALLOWED_ORIGINS=https://scrapalot.app,https://app.scrapalot.app

# Production Redis
# REDIS_ENABLED=true
# REDIS_HOST=redis
# REDIS_PASSWORD=your-redis-password
# REDIS_DB=1

# Production Profile
# SPRING_PROFILES_ACTIVE=prod

# Production API Docs (disabled)
# SPRINGDOC_ENABLED=false
# SWAGGER_UI_ENABLED=false

# Production gRPC
# GRPC_REFLECTION_ENABLED=false

# Production Java Options
# JAVA_OPTS=-Xms512m -Xmx2048m -XX:+UseG1GC -XX:MaxGCPauseMillis=200
