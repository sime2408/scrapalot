{
    "compilerOptions": {
        "target": "ES2022",
        "lib": [
            "ES2022",
            "DOM"
        ],
        "module": "commonjs",
        "moduleResolution": "node",
        "types": [
            "node",
            "@playwright/test"
        ],
        "esModuleInterop": true,
        "strict": false,
        "skipLibCheck": true,
        "noImplicitAny": false,
        "noUnusedParameters": false,
        "noUnusedLocals": false,
        "allowSyntheticDefaultImports": true,
        "resolveJsonModule": true
    },
    "include": [
        "tests/**/*.ts"
    ]
}