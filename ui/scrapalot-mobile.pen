              "name": "pdfTitle",
              "fill": "#E4E4E7",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "A Comprehensive Review of\nConsciousness Research",
              "lineHeight": 1.3,
              "fontFamily": "Merriweather",
              "fontSize": 20,
              "fontWeight": "700"
            },
            {
              "type": "text",
              "id": "8we9V",
              "name": "pdfAuthor",
              "fill": "#71717A",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "Dr. Sarah Chen, Department of Cognitive Neuroscience\nUniversity of California, Berkeley",
              "lineHeight": 1.4,
              "fontFamily": "Merriweather",
              "fontSize": 11,
              "fontWeight": "normal",
              "fontStyle": "italic"
            },
            {
              "type": "rectangle",
              "id": "xcV8g",
              "name": "pdfDiv",
              "fill": "#FFFFFF10",
              "width": "fill_container",
              "height": 1
            },
            {
              "type": "text",
              "id": "bDlwI",
              "name": "pdfAbsTitle",
              "fill": "#D4D4D8",
              "content": "Abstract",
              "fontFamily": "Merriweather",
              "fontSize": 14,
              "fontWeight": "700"
            },
            {
              "type": "text",
              "id": "VgcXM",
              "name": "pdfAbsText",
              "fill": "#A1A1AA",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "This paper presents a comprehensive review of contemporary consciousness research, examining neural correlates of awareness, integrated information theory, and emerging frameworks for understanding subjective experience. We analyze data from 147 peer-reviewed studies spanning 2018-2024, revealing significant advances in our understanding of how neural processes give rise to conscious awareness.",
              "lineHeight": 1.6,
              "fontFamily": "Merriweather",
              "fontSize": 12,
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "yizbn",
              "name": "pdfIntro",
              "fill": "#D4D4D8",
              "content": "1. Introduction",
              "fontFamily": "Merriweather",
              "fontSize": 13,
              "fontWeight": "700"
            },
            {
              "type": "text",
              "id": "iZG5s",
              "name": "pdfIntroText",
              "fill": "#A1A1AA",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "The study of consciousness remains one of the most fundamental challenges in modern neuroscience. Despite significant methodological advances in neuroimaging and computational modeling, the mechanisms underlying subjective experience continue to elude comprehensive explanation.",
              "lineHeight": 1.6,
              "fontFamily": "Merriweather",
              "fontSize": 11,
              "fontWeight": "normal"
            }
          ]
        },
