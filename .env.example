# Scrapalot Community Edition — environment template.
# Copy to .env and fill in. NEVER commit a real .env. All values below are placeholders.

# ── Database (Postgres + pgvector) ───────────────────────────────────
POSTGRES_USER=scrapalot
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=scrapalot
POSTGRES_HOST=pgvector
POSTGRES_PORT=5432
# Kotlin backend uses the scrapalot_backend database on the same server:
POSTGRES_BACKEND_HOST=pgvector
POSTGRES_BACKEND_PORT=5432
POSTGRES_BACKEND_DB=scrapalot_backend
POSTGRES_BACKEND_USER=scrapalot
POSTGRES_BACKEND_PASSWORD=change-me-strong-password

# ── Redis ────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ── JWT (must be identical across gateway, backend and chat; 32+ chars) ─
JWT_SECRET=change-me-to-a-random-32-plus-char-secret

# ── LLM provider (Bring Your Own Key) ────────────────────────────────
# Set the key for whichever provider you use, or point at a local model.
OPENAI_API_KEY=sk-proj-REPLACE_WITH_YOUR_OPENAI_KEY
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
# Local inference (llama.cpp / GGUF) needs no key.

# ── Knowledge graph: DISABLED in the Community Edition ───────────────
NEO4J_ENABLED=false

# ── OAuth (optional — leave blank to disable Google sign-in) ─────────
GOOGLE_OAUTH_ENABLED=false
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# ── App ──────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
APP_ENV=production
