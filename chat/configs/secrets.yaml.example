# =============================================================================
# SECRETS CONFIGURATION TEMPLATE
# =============================================================================
# Copy this file to secrets.yaml:
#   cp secrets.yaml.example secrets.yaml
#
# NOTE: secrets.yaml is gitignored - never commit real production secrets!
#
# Environment variables ALWAYS win over this file (see load_secrets() in
# src/main/utils/config_loader.py). For production, set these as env vars:
#   - POSTGRES_PASSWORD
#   - REDIS_PASSWORD
#   - NEO4J_PASSWORD
#   - JWT_SECRET
#   - SERPAPI_KEY
#   - GOOGLE_SEARCH_API_KEY
#   - GOOGLE_SEARCH_ENGINE_ID
#   - HUGGINGFACE_TOKEN
#   - GOOGLE_OAUTH_CLIENT_SECRET
#   - FIRECRAWL_API_KEY
#   - TAVILY_API_KEY
#   - STRIPE_SECRET_KEY
#   - STRIPE_WEBHOOK_SECRET
#
# LLM provider API keys (openai / anthropic / google-genai) are stored in the
# database (server_settings.system_agent_config) and configured via admin UI,
# NOT here. Reranker keys (cohere, jina) are loaded directly from yaml if set.
# =============================================================================

# -----------------------------------------------------------------------------
# Database Passwords
# -----------------------------------------------------------------------------
postgres_password: "scrapalot"
redis_password: ""
neo4j_password: "ineedastrongerpassword"

# -----------------------------------------------------------------------------
# Authentication Secrets
# -----------------------------------------------------------------------------
# Generate a secure JWT secret with:
#   python -c "import secrets; print(secrets.token_hex(32))"
jwt_secret: "local_dev_jwt_secret_change_in_production"
google_oauth_client_secret: ""

# -----------------------------------------------------------------------------
# LLM / AI Provider API Keys (prefer DB config via admin UI)
# -----------------------------------------------------------------------------
openai_api_key: ""
anthropic_api_key: ""
huggingface_token: "hf_xxx"

# -----------------------------------------------------------------------------
# Reranker API Keys (cloud reranking providers)
# -----------------------------------------------------------------------------
cohere_reranker_api_key: ""
jina_reranker_api_key: ""

# -----------------------------------------------------------------------------
# Web Search / Crawling API Keys
# -----------------------------------------------------------------------------
serpapi_key: ""
google_search_api_key: ""
google_search_engine_id: ""
firecrawl_api_key: ""
tavily_api_key: ""

# -----------------------------------------------------------------------------
# Stripe (billing)
# -----------------------------------------------------------------------------
stripe_secret_key: ""
stripe_webhook_secret: ""
