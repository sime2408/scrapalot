# Redis Configuration (Local Development)
REDIS_HOST=localhost
REDIS_PORT=6479

# Stripe Configuration
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_REPLACE_WITH_YOUR_KEY
STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_WITH_YOUR_KEY

# Webhook Secret - Get from https://dashboard.stripe.com/webhooks
# Create webhook endpoint pointing to: https://your-domain.com/api/v1/subscriptions/webhook
# Listen for: checkout.session.completed, customer.subscription.updated, customer.subscription.deleted, invoice.payment_succeeded, invoice.payment_failed
STRIPE_WEBHOOK_SECRET=whsec_test_placeholder

# Redirect URLs
STRIPE_SUCCESS_URL=http://localhost:3000/dashboard?session_id={CHECKOUT_SESSION_ID}
STRIPE_CANCEL_URL=http://localhost:3000/pricing
STRIPE_PORTAL_RETURN_URL=http://localhost:3000/settings/subscription

# OpenAI Configuration
OPENAI_API_KEY=sk-proj-REPLACE_WITH_YOUR_OPENAI_KEY

# Neo4j Configuration (Docker)
# CRITICAL: Password MUST match running Docker container
# Verified with: docker exec neo4j printenv | grep NEO4J_AUTH
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=ineedastrongerpassword
NEO4J_ENABLED=true
