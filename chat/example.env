ENVIRONMENT=dev
POSTGRES_USER=scrapalot
POSTGRES_PASSWORD=scrapalot
POSTGRES_DB=scrapalot
POSTGRES_HOST=localhost
POSTGRES_PORT=15432
POSTGRES_FALLBACK_TO_SQLITE=true

# For production (Supabase), set these environment variables in your deployment platform:
# POSTGRES_HOST=db.slqspvtyrgzhanubcdtj.supabase.co
# POSTGRES_PORT=5432
# POSTGRES_DB=postgres
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=****
# POSTGRES_FALLBACK_TO_SQLITE=false
# Migrations
ENABLE_MIGRATIONS=1
# Web Search APIs
SERPAPI_KEY=your_serpapi_key_here
# Get your Firecrawl API Key here: https://www.firecrawl.dev/
FIRECRAWL_API_KEY=fc-xxx
# Hugging Face - used for model listings and downloads (https://huggingface.co/settings/tokens)
HUGGINGFACE_TOKEN=hf_xxx
# Disable Hugging Face symlinks warning
HF_HUB_DISABLE_SYMLINKS_WARNING=true
# graph rag
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=ineedastrongerpassword
NEO4J_AUTH=neo4j/ineedastrongerpassword
NEO4J_PAGECACHE_SIZE=512M
NEO4J_HEAP_SIZE=512M

# Google OAuth Configuration (User Authentication)
GOOGLE_OAUTH_CLIENT_ID=****.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=****
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8090/api/v1/auth/google/callback
GOOGLE_OAUTH_ENABLED=true

# Frontend Configuration
FRONTEND_URL=http://localhost:3000

# Backend Configuration (for OAuth redirects)
# For local development: http://localhost:8090
# For production: https://scrapalot.app/api
BACKEND_BASE_URL=http://localhost:8090
