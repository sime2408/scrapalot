# ===========================================
# ENVIRONMENT CONFIGURATION
# ===========================================
ENVIRONMENT=development

# ===========================================
# DATABASE - PostgreSQL
# ===========================================
POSTGRES_HOST=pgvector
POSTGRES_PORT=15432
POSTGRES_USER=scrapalot
POSTGRES_PASSWORD=scrapalot
POSTGRES_DB=scrapalot
POSTGRES_FALLBACK_TO_SQLITE=false
POSTGRES_SSL_MODE=disable

# ===========================================
# CACHE - Redis
# ===========================================
REDIS_URL=redis://redis:6379
REDIS_PASSWORD=

# ===========================================
# GRAPH DATABASE - Neo4j
# ===========================================
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=ineedastrongerpassword
NEO4J_AUTH=neo4j/ineedastrongerpassword
# Memory tuning: pagecache MUST be >= store size to prevent idle CPU spikes
# Check store size: docker exec neo4j du -sh /data/databases/neo4j/
NEO4J_HEAP_SIZE=768M
NEO4J_PAGECACHE_SIZE=896M
GRAPH_ENABLED=true

# ===========================================
# AUTHENTICATION & SECURITY
# ===========================================
# JWT secret must match between all services (gateway, backend, chat)
JWT_SECRET=8f4b6c2a1e9d7f3b5a0c8e6d4a2b0f1e

# OAuth Configuration (User Authentication)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://scrapalot.app/api/v1/auth/google/callback

# ===========================================
# EXTERNAL AI PROVIDERS
# ===========================================
# LLM API keys (OPENAI_API_KEY, ANTHROPIC_API_KEY) are now in the database
# (server_settings.system_agent_config), configured via admin UI.
HUGGINGFACE_TOKEN=hf_xxx

# ===========================================
# EXTERNAL SERVICES (Search & Scraping)
# ===========================================
FIRECRAWL_API_KEY=fc-xxx
SERPAPI_KEY=xxx
ANNAS_ARCHIVE_API_KEY=
ANNAS_MEMBER_SECRET_KEY=

# ===========================================
# APPLICATION URLs
# ===========================================
FRONTEND_URL=https://scrapalot.app
BACKEND_BASE_URL=https://api.scrapalot.app
VITE_API_BASE_URL=
VITE_LLM_INFERENCE_ENDPOINT=

# ===========================================
# GITHUB INTEGRATION
# ===========================================
GITHUB_TOKEN=github_pat_xxx
GH_TOKEN=github_pat_xxx

# ===========================================
# HuggingFace Configuration
# ===========================================
HF_HUB_DISABLE_SYMLINKS_WARNING=true

# ===========================================
# Application Paths (Docker internal)
# ===========================================
SCRAPALOT_CACHE_DIR=/app/data/cache
PYTHONPATH=/app
PYTHONUNBUFFERED=1
HF_HOME=/app/data/models/huggingface
HUGGINGFACE_HUB_CACHE=/app/data/models/huggingface
HF_HUB_DISABLE_SYMLINKS=1
HF_HUB_DISABLE_TELEMETRY=1
HF_HUB_OFFLINE=0
TRANSFORMERS_OFFLINE=0
LLM_MODELS_DIRECTORY=/app/data/models
UPLOAD_PATH=/app/data/upload
ENABLE_MIGRATIONS=1

# Vulkan Configuration (disabled by default)
LLM_VULKAN_ENABLED=false
LLM_VULKAN_PREFER=false

# OpenAI API Key (for LLM calls in chat tests)
OPENAI_API_KEY=sk-xxx

# Stripe Payment Integration
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_TEST_MODE=true
