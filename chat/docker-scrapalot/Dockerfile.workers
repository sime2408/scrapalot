# =============================================================================
# SCRAPALOT WORKERS — GPU-CAPABLE DOCKERFILE
#
# Extends the base Python dependencies with CUDA support for GPU-accelerated
# OCR (Docling CUDA) on a dedicated GPU server.
#
# CPU workers (local dev / cloud): use the standard scrapalot-chat image
#   docker compose up scrapalot-workers  (image: scrapalot-chat:latest)
#
# GPU workers (dedicated GPU server): build this image
#   docker build -f docker-scrapalot/Dockerfile.workers -t scrapalot-workers-cuda:latest .
#   docker compose -f docker-compose.yaml -f docker-compose.gpu-workers.yml up scrapalot-workers
# =============================================================================

# syntax=docker/dockerfile:1.4

# -----------------------------------------------------------------------------
# Stage 1: CUDA Base
# CUDA 12.1 with cuDNN 8 — compatible with PyTorch 2.5.x cu121 wheels
# -----------------------------------------------------------------------------
FROM nvidia/cuda:12.1.0-cudnn8-runtime-ubuntu22.04 AS cuda-base

# Install Python 3.12 (not bundled with this CUDA image)
# + supervisor (PRD prd_onyx_worker_stability.md Phase 3 — per-queue worker
# split; the compose `command: [supervisord, ...]` requires this binary).
RUN apt-get update && apt-get install -y --no-install-recommends \
    software-properties-common \
    && add-apt-repository ppa:deadsnakes/ppa \
    && apt-get update && apt-get install -y --no-install-recommends \
    python3.12 \
    python3.12-dev \
    python3.12-distutils \
    python3-pip \
    libpq-dev \
    curl \
    git \
    wget \
    build-essential \
    gcc \
    g++ \
    cmake \
    pkg-config \
    sqlite3 \
    supervisor \
    && rm -rf /var/lib/apt/lists/*

# Make python3.12 the default python
RUN update-alternatives --install /usr/bin/python python /usr/bin/python3.12 1 \
    && update-alternatives --install /usr/bin/python3 python3 /usr/bin/python3.12 1

# Upgrade pip
RUN python -m pip install --upgrade pip setuptools wheel

ENV PIP_PREFER_BINARY=1
ENV PYTHONPATH=/app
ENV PYTHONUNBUFFERED=1

WORKDIR /app

# -----------------------------------------------------------------------------
# Stage 2: GPU Dependencies
# -----------------------------------------------------------------------------
FROM cuda-base AS gpu-deps

# Copy requirements
COPY requirements.txt requirements-gpu.txt /tmp/

# Install PyTorch with CUDA 12.1 support (replaces CPU version from requirements.txt)
RUN --mount=type=cache,target=/root/.cache/pip \
    pip install \
    --index-url https://download.pytorch.org/whl/cu121 \
    torch==2.5.1 \
    torchvision==0.20.1 \
    torchaudio==2.5.1

# Install core dependencies
RUN --mount=type=cache,target=/root/.cache/pip \
    pip install \
    psycopg2-binary==2.9.9 \
    asyncpg==0.30.0 \
    fastapi==0.116.1 \
    "uvicorn[standard]>=0.32.0,<1.0.0" \
    sqlalchemy==2.0.44 \
    pydantic[email]==2.11.9

# Install scientific packages
RUN --mount=type=cache,target=/root/.cache/pip \
    pip install \
    "numpy>=1.26.0,<3.0" \
    "pandas>=2.2.0,<3.0" \
    "scikit-learn>=1.5.0,<2.0" \
    "scipy>=1.13.0,<2.0"

# Install remaining requirements (excluding torch, llama-cpp, surya, marker)
RUN --mount=type=cache,target=/root/.cache/pip \
    grep -v "surya-ocr" /tmp/requirements.txt | \
    grep -v "marker-pdf" | \
    grep -v "torch==" | grep -v "torchvision==" | grep -v "torchaudio==" | \
    grep -v "llama-cpp-python" | \
    grep -v "^--" | grep -v "^#" | grep -v "^$" | \
    sed 's/#.*//' | sed '/^[[:space:]]*$/d' > /tmp/requirements_gpu_filtered.txt && \
    pip install -r /tmp/requirements_gpu_filtered.txt

# Patch pymupdf4llm-layout: add null check for PDFs without StructTreeRoot
# Bug: parse_document() crashes with FzErrorArgument on PDFs with null catalog root
# Upstream: pymupdf4llm 1.27.2.1 — remove this patch when fixed in a future release
RUN LAYOUT_FILE=$(python -c "import pymupdf4llm.helpers.document_layout as m; print(m.__file__)") && \
    sed -i 's/        root\.pdf_dict_del(pymupdf\.PDF_NAME("StructTreeRoot"))/        if root.m_internal:\n            root.pdf_dict_del(pymupdf.PDF_NAME("StructTreeRoot"))/' "$LAYOUT_FILE" && \
    echo "Patched pymupdf4llm-layout StructTreeRoot null check"

# Install neo4j packages (installed separately because requirements.txt is
# filtered with `grep -v neo4j` above). With deps now: langchain-neo4j 0.10
# supports langchain-core 1.x and pulls neo4j-graphrag, which resolves cleanly
# on numpy 2.x — the old 0.5.0 `--no-deps` workaround for the numpy conflict is
# no longer needed.
RUN --mount=type=cache,target=/root/.cache/pip \
    pip install \
    "neo4j==5.28.2" \
    "langchain-neo4j==0.10.0" && \
    pip install pytz

# Install GPU requirements (Docling CUDA, etc.) if requirements-gpu.txt exists
RUN --mount=type=cache,target=/root/.cache/pip \
    if [ -f /tmp/requirements-gpu.txt ]; then \
        pip install -r /tmp/requirements-gpu.txt; \
    fi

# Pre-download spaCy model
RUN --mount=type=cache,target=/root/.cache/pip \
    pip install https://github.com/explosion/spacy-models/releases/download/en_core_web_md-3.8.0/en_core_web_md-3.8.0-py3-none-any.whl || \
    echo "SpaCy model download failed, will retry at runtime"

# -----------------------------------------------------------------------------
# Target: GPU worker image
# -----------------------------------------------------------------------------
FROM gpu-deps AS workers

WORKDIR /app

# Non-root runtime user; mirrors the CPU image (see Dockerfile). UID 1000
# is in the supplementary `scrapalot-dev` group (GID 1002) so bind-mounted
# host source/configs are readable.
RUN groupadd -g 1000 scrapalot && \
    groupadd -g 1002 scrapalot-dev && \
    useradd -u 1000 -g scrapalot -G scrapalot-dev -m -s /bin/bash scrapalot

# Create necessary directories
RUN mkdir -p /app/data /app/data/models /app/data/logs /app/data/cache \
             /app/data/db /app/data/upload && \
    chown -R 1000:1000 /app/data && \
    chmod -R 755 /app/data

# Copy application files
COPY --chown=1000:1000 src/ ./src/
COPY --chown=1000:1000 alembic/ ./alembic/
COPY --chown=1000:1000 configs/ ./configs/
COPY --chown=1000:1000 scripts/ ./scripts/
COPY --chown=1000:1000 run_service.py alembic.ini __init__.py ./

# Environment variables
ENV PYTHONPATH=/app
ENV PYTHONUNBUFFERED=1
ENV ENVIRONMENT=prod
ENV HF_HOME=/app/data/models/huggingface
ENV HUGGINGFACE_HUB_CACHE=/app/data/models/huggingface
ENV HF_HUB_DISABLE_SYMLINKS=1
ENV HF_HUB_DISABLE_TELEMETRY=1
ENV HF_HUB_OFFLINE=0
ENV TRANSFORMERS_OFFLINE=0
ENV UPLOAD_PATH=/app/data/upload
ENV LLM_MODELS_DIRECTORY=/app/data/models
ENV SCRAPALOT_CACHE_DIR=/app/data/cache
ENV NVIDIA_VISIBLE_DEVICES=all
ENV NVIDIA_DRIVER_CAPABILITIES=compute,utility

ARG BUILD_DATE=unknown
RUN echo "Build date: $BUILD_DATE" > /app/build_info.txt && \
    chown 1000:1000 /app/build_info.txt

# Drop-root entrypoint. Mirrors the CPU image — reconciles
# bind-mounted /app/data ownership with uid 1000 before launching Celery.
COPY docker-scrapalot/entrypoint.sh /app/entrypoint.sh
RUN chmod +x /app/entrypoint.sh

# supervisord config for Phase 3 per-queue worker split. Used ONLY when
# the container is launched via compose CMD override (supervisord -c ...).
# scrapalot-dev group (gid 1002) per workspace CLAUDE.md so github-runner
# can also inspect/edit the file on the host.
COPY --chown=1000:1002 docker-scrapalot/supervisord.conf /app/supervisord.conf

ENTRYPOINT ["/app/entrypoint.sh"]

# Default CMD — compose overrides this with `[supervisord, -c,
# /app/supervisord.conf, -n]` for the per-queue split (Phase 3).
# Standalone GPU debugging may invoke this CMD directly; threads pool +
# concurrency=1 match the Phase 0/1 defaults.
CMD ["celery", "-A", "src.main.workers.celery_app", "worker", \
     "--queues=documents,fast", \
     "--concurrency=1", \
     "--pool=threads", \
     "--loglevel=info"]
